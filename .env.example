# Underlay instance the prebuild reads the three reviverestore collections from
UNDERLAY_API_URL=https://dev.underlay.org

# API key for the prebuild fetch. Collections are public, but an authenticated
# read raises the rate limit (60/min anon -> 5k/min) so the ~140-page fetch
# doesn't get throttled. Any read-scoped reviverestore/dev key works.
UNDERLAY_API_KEY=ul_your_key_here

# Public Underlay base URL used for "view in Underlay" links in the UI
VITE_UNDERLAY_URL=https://dev.underlay.org
